# ====================
# Fyrstikken Environment Variables
# ====================
# Copy this file to .env and fill in the values.
# Most values have working defaults for development.

# --------------------
# Sanity CMS (Required for content)
# --------------------
# Get these from https://www.sanity.io/manage
# Project ID is public (safe to commit)
PUBLIC_SANITY_PROJECT_ID="531mn2v8"
PUBLIC_SANITY_DATASET="production"

# --------------------
# Site Configuration
# --------------------
# Base URL path if deploying to a subdirectory (e.g., "/Fyrstikken/")
# Leave empty for root deployment
# BASE_URL=""

# --------------------
# Build Configuration
# --------------------
# Astro automatically sets these - no need to configure:
# - import.meta.env.PROD (true in production builds)
# - import.meta.env.DEV (true in development)
# - import.meta.env.BASE_URL (from astro.config.mjs)

# --------------------
# Project Submissions (Required for /send-inn)
# --------------------
# Write token for creating draft projects via the submission form.
# Create at: https://www.sanity.io/manage → API → Tokens → Add token (Editor role)
# This is a SECRET - never commit the actual value.
# In production, set as a Cloudflare secret: wrangler secret put SANITY_WRITE_TOKEN
# SANITY_WRITE_TOKEN=""
