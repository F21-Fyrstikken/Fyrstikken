{
  "name": "fyrstikken",
  "description": "Award ceremony website for F21 VGS student projects",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev",
    "dev:studio": "sanity dev",
    "build": "astro build",
    "build:studio": "sanity build studio -y",
    "build:all": "pnpm build && pnpm build:studio && node scripts/copy-studio.js",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,astro}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@sanity/astro": "^3.2.10",
    "@sanity/client": "^7.11.0",
    "astro": "^5.13.5",
    "astro-portabletext": "^0.11.3",
    "sanity": "^4.6.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^24.7.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-sonarjs": "^3.0.5",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0"
  }
}
