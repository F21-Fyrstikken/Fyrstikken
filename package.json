{
  "name": "fyrstikken",
  "description": "Award ceremony website for F21 VGS student projects",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "astro dev",
    "dev:studio": "sanity dev",
    "build": "astro build",
    "build:studio": "sanity build studio -y",
    "build:all": "pnpm build && pnpm build:studio && node scripts/copy-studio.js",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,astro}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@sanity/astro": "^3.2.11",
    "@sanity/client": "^7.15.0",
    "astro": "^5.17.3",
    "astro-portabletext": "^0.11.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanity": "^4.22.0",
    "sharp": "^0.34.5",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@portabletext/types": "^4.0.1",
    "@types/node": "^24.10.13",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^3.0.7",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
