---
import "../styles/global.css";
import "../styles/typografi.css";
import Breadcrumb from "../components/common/Breadcrumb.astro";
import type { IBaseLayoutProps, IBreadcrumbItem } from "../types";
import { SITE_CONFIG } from "../config";

const { title = "Fyrstikken", description, image } = Astro.props as IBaseLayoutProps;
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? SITE_CONFIG.fallbackUrl);
const ogImage = image ?? `${canonicalUrl.origin}${base}og-image.png`;

const basePath = base.replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(basePath, "").replace(/\/$/, "") || "/";
const isHomePage = pathname === "/";

const segmentLabels: Record<string, string> = {
  years: "År",
  about: "Om",
  "send-inn": "Send inn",
};

function buildBreadcrumbs(path: string): IBreadcrumbItem[] {
  if (path === "/") return [];
  const segments = path.split("/").filter(Boolean);
  const items: IBreadcrumbItem[] = [{ label: "Hjem", href: "/" }];
  let href = "";
  for (const segment of segments) {
    href += `/${segment}`;
    const label = segmentLabels[segment] || decodeURIComponent(segment);
    items.push({ label, href });
  }
  return items;
}

const breadcrumbItems = buildBreadcrumbs(pathname);
---

<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="nb_NO" />
    <meta property="og:site_name" content="Fyrstikken" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl.href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl.href} />
  </head>
  <body>
    <a href="#main-content" class="skiplink">Hopp til hovedinnhold</a>
    <slot name="header" />
    <!-- <nav class="main-nav" aria-label="Hovednavigasjon">
      <div class="nav-content">
        <Link href={base} class="nav-link">Hjem</Link>
        <Link href={`${base}about/`} class="nav-link">Arrangementet</Link>
        <Link href={`${base}years/`} class="nav-link">År</Link>
      </div>
    </nav> -->
    <main class="main-content" id="main-content">
      <section>
        {!isHomePage && breadcrumbItems.length > 0 && <Breadcrumb items={breadcrumbItems} basePath={basePath} />}
        <slot />
      </section>
    </main>
    <footer>
      <p
        >Opphavsrett © <span id="copyright">{new Date().getFullYear().toString()}</span> Fyrstikk-komitèen. Alle rettigheter
        hevdet</p
      >
    </footer>
  </body>
</html>

<style>
  .skiplink {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: light-dark(var(--light-safir), var(--dark-safir));
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0 0 8px 8px;
    text-decoration: none;
    font-weight: 600;
    z-index: 1000;
    transition: top 0.2s ease;
  }

  .skiplink:focus {
    top: 0;
  }

  body {
    display: grid;
    grid-template-rows: auto 1fr auto;
    background: light-dark(var(--light-bakgrunn), var(--dark-bakgrunn));
    color: light-dark(var(--light-tekst), var(--dark-tekst));
    min-height: 100vh;
    max-width: 1600px;
    margin-inline: auto;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
    line-height: 1.6;
  }

  main {
    background: light-dark(var(--light-main), var(--dark-main));
    color: light-dark(var(--light-tekst), var(--dark-tekst));
    height: fit-content;
    padding-inline: var(--space-xl);
    padding-block: var(--space-md);
  }

  .main-content {
    min-height: 60vh;
  }

  footer {
    position: fixed;
    bottom: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: light-dark(var(--light-tekstBoks), var(--dark-tekstBoks));
    border-top: 3px solid light-dark(var(--light-ramme), var(--dark-ramme));
    height: 3rem;
    width: 100%;
    box-shadow: 0px 1px 5px 0px rgba(0, 0, 0, 0.2);
  }

  /* @media (max-width: 768px) {
    .nav-content {
      padding: 0 1rem;
      gap: 1rem;
    }
  } */
</style>
<script>
  import { getCopyRightYear } from "../lib/utils"; // import i script for å være client-side
  const year = getCopyRightYear();
  const copyright = document.getElementById("copyright") as unknown as HTMLParagraphElement;
  copyright.textContent = year.toString();
</script>
