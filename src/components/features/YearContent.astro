---
import ProjectCard from "../common/ProjectCard.astro";
import ProjectModal from "../common/ProjectModal.astro";
import VoteButton from "./VoteButton.astro";
import VoteModal from "../VoteModal.astro";
import { THEME_COLORS } from "../../config";
import type { IYearContentProps } from "../../types";
import { getImageUrl, getImageAlt } from "../../utils/sanity";

const { yearData, categories, showVoting = true } = Astro.props as IYearContentProps;

const hasCategories = categories && categories.length > 0;
---

<div>
  <div class="page-header-content">
    <h1>Fyrstikken {yearData.year}</h1>
    {yearData.description && <p class="year-description">{yearData.description}</p>}
  </div>

  <div class="kategorier">
    {
      categories.map((category, index) => (
        <a
          class="kategori-knapp"
          href={"#" + category.slug.current}
          style={`--btn-light-color: ${THEME_COLORS[index % THEME_COLORS.length].light}; --btn-dark-color: ${THEME_COLORS[index % THEME_COLORS.length].dark};`}>
          {category.title}
        </a>
      ))
    }
  </div>

  {
    hasCategories ? (
      <div class="year-content">
        {categories.map((category, index) => {
          const hasProjects = category.projects && category.projects.length > 0;

          return (
            <section
              class="category-section"
              id={category.slug.current}
              style={`--category-light-color: ${THEME_COLORS[index % THEME_COLORS.length].light}; --category-dark-color: ${THEME_COLORS[index % THEME_COLORS.length].dark};`}>
              <div class="category-header">
                <div class="category-header-row">
                  {category.coverImage && (
                    <div
                      class="kategori-icon"
                      role="img"
                      aria-label={getImageAlt(category.coverImage, category.title)}
                      style={`--mask-url: url(${getImageUrl(category.coverImage)});`}
                    />
                  )}
                  <h2 class="category-title">{category.title}</h2>
                  {showVoting && <VoteButton categoryIndex={index} />}
                </div>
                {category.description && <p class="category-description">{category.description}</p>}
              </div>

              {hasProjects && (
                <div class="projects-grid">
                  {category.projects?.map((project) => (
                    <ProjectCard project={project} />
                  ))}
                </div>
              )}
            </section>
          );
        })}
        {showVoting && <VoteModal />}
        <ProjectModal />
      </div>
    ) : (
      <p>Ingen kategorier funnet for dette året.</p>
    )
  }
</div>

<a href="#" class="scroll-to-top" id="scrollToTop" aria-label="Scroll til toppen">
  <div class="svgIkon" id="pilOpp"></div>
</a>

<script>
  const btn = document.getElementById("scrollToTop");
  const kategorier = document.querySelector(".kategorier");

  if (btn && kategorier) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        btn.classList.toggle("visible", !entry.isIntersecting);
      },
      { threshold: 0 }
    );
    observer.observe(kategorier);
  }
</script>

<style>
  .year-description {
    font-size: 1.2rem;
    opacity: 0.85;
    margin-top: 0.75rem;
    font-weight: 400;
  }

  .year-content {
    margin-top: 2rem;
    margin-bottom: 10rem;
  }

  .kategorier {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .kategori-knapp {
    background-color: light-dark(var(--light-ixDBoks), var(--dark-ixDBoks));
    padding: 0.5rem 1.5rem;
    border: 2px solid light-dark(var(--btn-light-color), var(--btn-dark-color));
    border-radius: 6px;
    font-weight: normal;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .kategori-knapp:hover {
    box-shadow: inset 0 0 0 1000px
      light-dark(
        color-mix(in srgb, var(--btn-light-color) 10%, transparent),
        color-mix(in srgb, var(--btn-dark-color) 10%, transparent)
      );
  }

  /* Sikre at ikon og tittel er på samme linje */
  .category-header-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .category-section {
    margin-bottom: 4rem;
    padding: 1.5rem;
    border-radius: 1rem;
  }

  .category-section.voting {
    background-color: light-dark(
      color-mix(in srgb, var(--category-light-color) 10%, transparent),
      color-mix(in srgb, var(--category-dark-color) 10%, transparent)
    );
  }

  .category-header {
    margin-bottom: 2rem;
  }

  .category-header-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .category-header-row::before {
    content: "";
    flex: 1;
    height: 2px;
    background-color: light-dark(var(--category-light-color), var(--category-dark-color));
    order: 1;
  }

  .category-header-row :global(.vote-button) {
    order: 2;
  }

  .category-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: light-dark(var(--light-tekst), var(--dark-tekst));
  }

  .category-description {
    font-size: 1.1rem;
    opacity: 0.85;
    margin: 0;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
  }

  .svgIkon {
    width: 30px;
    height: 30px;
    object-fit: contain;
    vertical-align: middle;
    background-color: light-dark(var(--light-tekst), var(--dark-tekst));
    -webkit-mask: var(--ikon-url) no-repeat center / contain;
    mask: var(--ikon-url) no-repeat center / contain;
  }
  #pilOpp {
    --ikon-url: url(../../../public/ikonPilOpp.svg);
  }
  .kategoriIkon {
    background-color: light-dark(var(--light-tekst), var(--dark-tekst));

    width: 32px;
    height: 32px;
  }
  .kategori-icon {
    width: 32px;
    height: 32px;
    background-color: light-dark(var(--light-tekst), var(--dark-tekst));
    -webkit-mask: var(--mask-url) no-repeat center / contain;
    mask: var(--mask-url) no-repeat center / contain;
  }

  .scroll-to-top {
    position: fixed;
    bottom: 3rem;
    right: 2rem;
    color: inherit;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
    z-index: 100;
    text-decoration: none;
    border-radius: 50%;
    background-color: light-dark(var(--light-ixDBoks), var(--dark-ixDBoks));
  }

  .scroll-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-to-top:hover {
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .category-title {
      font-size: 1.75rem;
    }

    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .category-section {
      margin-bottom: 3rem;
    }
  }
  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
