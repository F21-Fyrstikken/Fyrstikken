---
export interface Vote {
  email: string;
  category_100?: number;
  category_200?: number;
  category_300?: number;
}
---

<form id="vote-form">
  <div>
    <label for="email">Email:</label>
    <input type="email" id="email" name="email" required />
  </div>
  <div>
    <label for="category_100">Category 100 (1-10):</label>
    <input type="number" id="category_100" name="category_100" min="1" max="10" />
  </div>
  <div>
    <label for="category_200">Category 200 (1-10):</label>
    <input type="number" id="category_200" name="category_200" min="1" max="10" />
  </div>
  <div>
    <label for="category_300">Category 300 (1-10):</label>
    <input type="number" id="category_300" name="category_300" min="1" max="10" />
  </div>
  <button type="submit">Submit Vote</button>
</form>

<script>
  document.getElementById("vote-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const vote: Vote = {
      email: formData.get("email") as string,
      category_100: formData.get("category_100") ? parseInt(formData.get("category_100") as string) : undefined,
      category_200: formData.get("category_200") ? parseInt(formData.get("category_200") as string) : undefined,
      category_300: formData.get("category_300") ? parseInt(formData.get("category_300") as string) : undefined,
    };
    try {
      const response = await fetch("https://fyrstikken-backend.infinitiwarrior.com/votes", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(vote),
      });
      if (response.ok) {
        alert("Vote submitted successfully!");
      } else {
        alert("Error submitting vote: " + response.statusText);
      }
    } catch (error) {
      console.error("Error:", error);
      alert("Error submitting vote");
    }
  });
</script>

<style>
  form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 400px;
  }
  label {
    font-weight: bold;
  }
  input {
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  button {
    padding: 0.5rem 1rem;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
  }
  button:hover {
    background-color: #0056b3;
  }
</style>
