---
import { colors } from "../constants/colors";

interface Props {
  categoryIndex: number;
}

const { categoryIndex } = Astro.props;

const colorIndex = categoryIndex % colors.length;
const categoryColor = colors[colorIndex];
const buttonId = `voteButton-${categoryIndex}`;
---

<button id={buttonId} class="vote-button" data-light-color={categoryColor.light} data-dark-color={categoryColor.dark}>
  Stem
</button>

<script>
  let activeButton: HTMLElement | null = null;
  let activeSection: HTMLElement | null = null;

  document.querySelectorAll(".vote-button").forEach((button) => {
    button.addEventListener("click", () => {
      const htmlButton = button as HTMLElement;
      const section = htmlButton.closest(".category-section") as HTMLElement;

      // Klikket på samme knapp som allerede er valgt - avbryt stemming
      if (activeButton === htmlButton) {
        htmlButton.classList.remove("vote");
        htmlButton.textContent = "Stem";
        section?.classList.remove("voting");
        activeButton = null;
        activeSection = null;
        return;
      }

      // Hvis en annen kategori var valgt fra før - fjern valget der
      if (activeButton) {
        activeButton.classList.remove("vote");
        activeButton.textContent = "Stem";
        activeSection?.classList.remove("voting");
      }

      // Velg denne kategorien for stemming
      htmlButton.classList.add("vote");
      htmlButton.textContent = "Avbryt";
      section?.classList.add("voting");
      activeButton = htmlButton;
      activeSection = section;
    });
  });
</script>

<style define:vars={{ "category-light-color": categoryColor.light, "category-dark-color": categoryColor.dark }}>
  button {
    color: light-dark(var(--light-tekst), var(--dark-tekst));
    background-color: light-dark(var(--light-ixDBoks), var(--dark-ixDBoks));
    padding: 1rem 3rem;
    border: 2px solid light-dark(var(--light-ramme), var(--dark-ramme));
    border-radius: 1rem;
    transition: border-color 0.3s ease;
  }

  button.vote {
    border-color: light-dark(var(--category-light-color), var(--category-dark-color));
  }
</style>
