---
/**
 * VideoEmbed - Responsive video embed container
 *
 * A shared component for embedding videos with consistent styling.
 * Maintains 16:9 aspect ratio and handles responsive sizing.
 *
 * @example
 * <VideoEmbed src="https://www.youtube.com/embed/VIDEO_ID" title="My Video" />
 */
interface Props {
  /** The embed URL for the video */
  src: string;
  /** Accessible title for the iframe */
  title: string;
  /** iframe allow attribute (permissions) */
  allow?: string;
}

const {
  src,
  title,
  allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen",
} = Astro.props;
---

<div class="video-container">
  <iframe src={src} title={title} frameborder="0" allow={allow} allowfullscreen></iframe>
</div>

<style>
  .video-container {
    position: relative;
    padding-bottom: var(--ratio-16-9); /* 16:9 aspect ratio from tokens */
    height: 0;
    overflow: hidden;
    margin: var(--space-2xl) 0;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    background: light-dark(var(--light-tekstBoks), var(--dark-tekstBoks));
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: var(--radius-lg);
  }

  @media (max-width: 768px) {
    .video-container {
      margin: var(--space-xl) 0;
    }
  }
</style>
