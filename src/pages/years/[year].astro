---
import BaseLayout from "../../layouts/BaseLayout.astro";
import YearContent from "../../components/features/YearContent.astro";
import { getAllYears, getCategoriesWithProjectsForYear } from "../../lib/sanity-client";
import { getBasePath } from "../../utils/paths";
import HeaderImg from "../../components/layout/HeaderImg.astro";
import { SITE_CONFIG } from "../../config"; // Importer konfigurasjonen

export async function getStaticPaths() {
  // 1. Fetch all available years
  const allYears = await getAllYears();

  // 2. FILTER UT inneværende år (2026)
  // Vi vil kun generere sider for tidligere år her
  const previousYears = allYears.filter((yearData) => yearData.year !== SITE_CONFIG.submissionYear);

  // 3. For each PREVIOUS year, fetch categories and projects
  return await Promise.all(
    previousYears.map(async (yearData) => {
      const yearString = yearData.year.toString();
      const categories = await getCategoriesWithProjectsForYear(yearString);

      return {
        params: { year: yearString },
        props: {
          yearData,
          categories,
        },
      };
    })
  );
}

const { year } = Astro.params;
const { yearData, categories } = Astro.props;
const basePath = getBasePath();

if (!year) {
  return Astro.redirect("/years/");
}
---

<BaseLayout title={`Fyrstikken ${year}`} description={`Kategorier for Fyrstikken ${year}`}>
  <HeaderImg variant="smal" slot="header" />
  <YearContent yearData={yearData} categories={categories} basePath={basePath} showVoting={false} />
</BaseLayout>
